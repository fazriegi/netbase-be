# ======================
# APP
# ======================
NAME="FINTRACK-BE"
ENV=development
PORT=8080

# ======================
# LOGGING
# ======================
LOG_FILE=./log/app.log

# ======================
# DATABASE
# ======================
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dbname
DB_SSLMODE=disable
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=${DB_SSLMODE}

# ======================
# JWT
# ======================
JWT_SECRET=secret_key_for_jwt

# ======================
# CORS
# ======================
ALLOWED_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

RAPID_API_KEY=xxxxx